# .env.example — Gemma 4 Research Agent (Phase 2 — LangChain)
# Copy this file to .env and fill in your values.
# Never commit .env to GitHub.

# HuggingFace token — required to load gated models like Gemma 4
# Get yours at: https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_token_here

# LangSmith API key — required for tracing
# Get yours at: https://smith.langchain.com/settings
LANGCHAIN_API_KEY=lsv2_your_key_here

# LangSmith tracing — set to "true" to enable, "false" to disable
LANGCHAIN_TRACING_V2=true

# LangSmith project name — traces will appear under this project
LANGCHAIN_PROJECT=gemma4-research-agent-phase2
