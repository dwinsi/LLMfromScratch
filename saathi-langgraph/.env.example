# Ollama configuration
SAATHI_OLLAMA_MODEL=gemma4:12b
SAATHI_OLLAMA_BASE_URL=http://localhost:11434

# LLM parameters
SAATHI_TEMPERATURE=0.1
SAATHI_CONTEXT_WINDOW=32768
SAATHI_MAX_TOKENS=4096

# Max tool calls to execute concurrently within a single turn
SAATHI_MAX_PARALLEL_TOOLS=8

# Optional: Brave Search API key (higher quality than DuckDuckGo)
SAATHI_BRAVE_API_KEY=

# Debug mode
SAATHI_DEBUG=false
